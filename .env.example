# Server Port
PORT=5000

# MongoDB Connection String (Replace with your own MongoDB Atlas URI)
# Format: mongodb+srv://<db_user>:<db_password>@<cluster_url>/<db_name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://admin:admin_password@cluster.example.mongodb.net/portfolio_db?retryWrites=true&w=majority
